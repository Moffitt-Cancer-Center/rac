# RAC Control Plane environment variables
# Copy to .env and fill in actual values for local development

# Deployment settings
RAC_ENV=dev
RAC_INSTITUTION_NAME=Moffitt Cancer Center
RAC_PARENT_DOMAIN=moffittcancer.org
RAC_BRAND_LOGO_URL=https://moffittcancer.org/logo.png

# IdP (Azure Entra) settings
RAC_IDP_TENANT_ID=00000000-0000-0000-0000-000000000000
RAC_IDP_CLIENT_ID=00000000-0000-0000-0000-000000000000
RAC_IDP_API_CLIENT_ID=00000000-0000-0000-0000-000000000000

# Database settings (PostgreSQL)
RAC_PG_HOST=localhost
RAC_PG_PORT=5432
RAC_PG_DB=rac
RAC_PG_USER=postgres
RAC_PG_PASSWORD=postgres
RAC_PG_SSL_MODE=disable

# Azure settings
RAC_KV_URI=https://rac-kv-dev.vault.azure.net/
RAC_BLOB_ACCOUNT_URL=https://racstoragedev.blob.core.windows.net/
RAC_ACR_LOGIN_SERVER=racregistrydev.azurecr.io
RAC_ACA_ENV_RESOURCE_ID=/subscriptions/00000000-0000-0000-0000-000000000000/resourceGroups/rac-rg/providers/Microsoft.App/managedEnvironments/rac-env

# Scan settings
RAC_SCAN_SEVERITY_GATE=high

# Approver roles
RAC_APPROVER_ROLE_RESEARCH=ResearchApprover
RAC_APPROVER_ROLE_IT=ITApprover

# Webhook settings
RAC_WEBHOOK_SECRET_ROTATION_DAYS=30

# Observability
RAC_OTLP_ENDPOINT=http://localhost:4317

# App Insights (optional)
# APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=...;IngestionEndpoint=...
