# RAC Control Plane Environment Configuration
# Copy this file to .env.local and fill in real values for your deployment.
# Safe placeholder values are provided for local development with mock-oidc.

# === Deployment ===
RAC_ENV=dev
RAC_INSTITUTION_NAME=Moffitt Cancer Center
RAC_PARENT_DOMAIN=localhost:8080
RAC_BRAND_LOGO_URL=https://moffitt.usf.edu/static/logo.png

# === Identity Provider (Entra/Azure AD) ===
RAC_IDP_TENANT_ID=12345678-1234-1234-1234-123456789012
RAC_IDP_CLIENT_ID=87654321-4321-4321-4321-210987654321
RAC_IDP_API_CLIENT_ID=11111111-2222-3333-4444-555555555555

# === Database (Postgres) ===
RAC_PG_HOST=postgres
RAC_PG_PORT=5432
RAC_PG_DB=rac
RAC_PG_USER=rac_app
RAC_PG_PASSWORD=devonly_rac_app
RAC_PG_SSL_MODE=disable

# === Azure Resources ===
RAC_KV_URI=https://rac-kv-dev.vault.azure.net/
RAC_BLOB_ACCOUNT_URL=https://racstoragedev.blob.core.windows.net/
RAC_ACR_LOGIN_SERVER=racacrdev.azurecr.io
RAC_ACA_ENV_RESOURCE_ID=/subscriptions/00000000-0000-0000-0000-000000000000/resourceGroups/rac-dev/providers/Microsoft.App/managedEnvironments/rac-env-dev

# === Scanning Configuration ===
RAC_SCAN_SEVERITY_GATE=high

# === Approval Roles ===
RAC_APPROVER_ROLE_RESEARCH=rac-approver-research
RAC_APPROVER_ROLE_IT=rac-approver-it

# === Webhooks ===
RAC_WEBHOOK_SECRET_ROTATION_DAYS=30

# === Observability ===
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
APPLICATIONINSIGHTS_CONNECTION_STRING=

# === Frontend (React Vite) ===
VITE_TENANT_ID=12345678-1234-1234-1234-123456789012
VITE_FRONTEND_CLIENT_ID=22222222-3333-4444-5555-666666666666
VITE_API_BASE_URL=/api
VITE_INSTITUTION_NAME=Moffitt Cancer Center
VITE_BRAND_LOGO_URL=https://moffitt.usf.edu/static/logo.png
