{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "languageVersion": "2.0",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.42.1.51946",
      "templateHash": "2749130694863053286"
    }
  },
  "parameters": {
    "location": {
      "type": "string",
      "metadata": {
        "description": "Azure region for all resources"
      }
    },
    "racEnv": {
      "type": "string",
      "metadata": {
        "description": "RAC deployment environment (dev, staging, prod)"
      }
    },
    "acrName": {
      "type": "string",
      "metadata": {
        "description": "Azure Container Registry name (globally unique, max 50 chars, alphanumeric)"
      }
    },
    "peSubnetId": {
      "type": "string",
      "metadata": {
        "description": "Private endpoint subnet resource ID"
      }
    },
    "vnetId": {
      "type": "string",
      "metadata": {
        "description": "VNet resource ID for private DNS zone linking"
      }
    },
    "controlPlaneMiPrincipalId": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Control Plane managed identity principal ID — granted AcrPull on this registry. Empty disables the assignment."
      }
    },
    "shimMiPrincipalId": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Shim managed identity principal ID — granted AcrPull on this registry. Empty disables the assignment."
      }
    },
    "tags": {
      "type": "object",
      "metadata": {
        "description": "Resource tags applied to all resources"
      }
    }
  },
  "variables": {
    "acrNameNormalized": "[toLower(parameters('acrName'))]",
    "roleIds": {
      "dnsZoneContributor": "befefa01-2a29-4197-83a8-272ff33ce314",
      "keyVaultCryptoOfficer": "14b46e9e-c2b7-41b4-b07b-48a6ebf60603",
      "keyVaultCryptoUser": "12338af0-0e69-4776-bea7-57ae8d297424",
      "keyVaultSecretsUser": "4633458b-17de-408a-b874-0445c86b69e6",
      "keyVaultCertificatesUser": "db79e9a7-68ee-4b58-9aeb-b90e7c24fcba",
      "contributor": "b24988ac-6180-42a0-ab88-20f7382dd24c",
      "storageAccountKeyOperatorServiceRole": "81a9662b-bebf-436f-a333-f67b29880f12",
      "acrPull": "7f951dda-4ed3-4680-a7ca-43fe172d538d"
    }
  },
  "resources": {
    "acr": {
      "type": "Microsoft.ContainerRegistry/registries",
      "apiVersion": "2023-11-01-preview",
      "name": "[variables('acrNameNormalized')]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "sku": {
        "name": "Premium"
      },
      "identity": {
        "type": "SystemAssigned"
      },
      "properties": {
        "adminUserEnabled": false,
        "publicNetworkAccess": "Disabled",
        "policies": {
          "quarantinePolicy": {
            "status": "disabled"
          }
        }
      }
    },
    "privateDnsZone": {
      "type": "Microsoft.Network/privateDnsZones",
      "apiVersion": "2020-06-01",
      "name": "privatelink.azurecr.io",
      "location": "global",
      "tags": "[parameters('tags')]"
    },
    "privateDnsZoneVnetLink": {
      "type": "Microsoft.Network/privateDnsZones/virtualNetworkLinks",
      "apiVersion": "2020-06-01",
      "name": "[format('{0}/{1}', 'privatelink.azurecr.io', 'vnet-link')]",
      "location": "global",
      "properties": {
        "registrationEnabled": false,
        "virtualNetwork": {
          "id": "[parameters('vnetId')]"
        }
      },
      "tags": "[parameters('tags')]",
      "dependsOn": [
        "privateDnsZone"
      ]
    },
    "privateEndpoint": {
      "type": "Microsoft.Network/privateEndpoints",
      "apiVersion": "2023-11-01",
      "name": "[format('pe-acr-{0}', parameters('racEnv'))]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "properties": {
        "subnet": {
          "id": "[parameters('peSubnetId')]"
        },
        "privateLinkServiceConnections": [
          {
            "name": "acr-connection",
            "properties": {
              "privateLinkServiceId": "[resourceId('Microsoft.ContainerRegistry/registries', variables('acrNameNormalized'))]",
              "groupIds": [
                "registry"
              ]
            }
          }
        ]
      },
      "dependsOn": [
        "acr"
      ]
    },
    "privateDnsZoneGroup": {
      "type": "Microsoft.Network/privateEndpoints/privateDnsZoneGroups",
      "apiVersion": "2023-11-01",
      "name": "[format('{0}/{1}', format('pe-acr-{0}', parameters('racEnv')), 'acr-zone-group')]",
      "properties": {
        "privateDnsZoneConfigs": [
          {
            "name": "acr-privatelink-zone",
            "properties": {
              "privateDnsZoneId": "[resourceId('Microsoft.Network/privateDnsZones', 'privatelink.azurecr.io')]"
            }
          }
        ]
      },
      "dependsOn": [
        "privateDnsZone",
        "privateEndpoint"
      ]
    },
    "acrPullForControlPlane": {
      "condition": "[not(empty(parameters('controlPlaneMiPrincipalId')))]",
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "scope": "[resourceId('Microsoft.ContainerRegistry/registries', variables('acrNameNormalized'))]",
      "name": "[guid(resourceId('Microsoft.ContainerRegistry/registries', variables('acrNameNormalized')), parameters('controlPlaneMiPrincipalId'), variables('roleIds').acrPull)]",
      "properties": {
        "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', variables('roleIds').acrPull)]",
        "principalId": "[parameters('controlPlaneMiPrincipalId')]",
        "principalType": "ServicePrincipal"
      },
      "dependsOn": [
        "acr"
      ]
    },
    "acrPullForShim": {
      "condition": "[not(empty(parameters('shimMiPrincipalId')))]",
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "scope": "[resourceId('Microsoft.ContainerRegistry/registries', variables('acrNameNormalized'))]",
      "name": "[guid(resourceId('Microsoft.ContainerRegistry/registries', variables('acrNameNormalized')), parameters('shimMiPrincipalId'), variables('roleIds').acrPull)]",
      "properties": {
        "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', variables('roleIds').acrPull)]",
        "principalId": "[parameters('shimMiPrincipalId')]",
        "principalType": "ServicePrincipal"
      },
      "dependsOn": [
        "acr"
      ]
    }
  },
  "outputs": {
    "acrId": {
      "type": "string",
      "metadata": {
        "description": "Container Registry resource ID"
      },
      "value": "[resourceId('Microsoft.ContainerRegistry/registries', variables('acrNameNormalized'))]"
    },
    "acrLoginServer": {
      "type": "string",
      "metadata": {
        "description": "Container Registry login server FQDN"
      },
      "value": "[reference('acr').loginServer]"
    },
    "acrResourceId": {
      "type": "string",
      "metadata": {
        "description": "Container Registry resource ID (alias for acrId)"
      },
      "value": "[resourceId('Microsoft.ContainerRegistry/registries', variables('acrNameNormalized'))]"
    }
  }
}