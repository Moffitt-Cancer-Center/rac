{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.42.1.51946",
      "templateHash": "9861008176244438127"
    }
  },
  "parameters": {
    "defaultDomain": {
      "type": "string",
      "metadata": {
        "description": "ACA env default domain, e.g. \"happyfield-f43dfd30.eastus2.azurecontainerapps.io\". Pass aca-env.outputs.envDefaultDomain."
      }
    },
    "staticIp": {
      "type": "string",
      "metadata": {
        "description": "ACA env static IP. Pass aca-env.outputs.envStaticIp."
      }
    },
    "vnetId": {
      "type": "string",
      "metadata": {
        "description": "VNet resource ID to link the private DNS zone to."
      }
    },
    "tags": {
      "type": "object",
      "metadata": {
        "description": "Resource tags applied to all resources"
      }
    }
  },
  "resources": [
    {
      "type": "Microsoft.Network/privateDnsZones",
      "apiVersion": "2020-06-01",
      "name": "[parameters('defaultDomain')]",
      "location": "global",
      "tags": "[parameters('tags')]"
    },
    {
      "type": "Microsoft.Network/privateDnsZones/virtualNetworkLinks",
      "apiVersion": "2020-06-01",
      "name": "[format('{0}/{1}', parameters('defaultDomain'), 'link-aca')]",
      "location": "global",
      "properties": {
        "registrationEnabled": false,
        "virtualNetwork": {
          "id": "[parameters('vnetId')]"
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Network/privateDnsZones', parameters('defaultDomain'))]"
      ]
    },
    {
      "type": "Microsoft.Network/privateDnsZones/A",
      "apiVersion": "2020-06-01",
      "name": "[format('{0}/{1}', parameters('defaultDomain'), '*')]",
      "properties": {
        "ttl": 3600,
        "aRecords": [
          {
            "ipv4Address": "[parameters('staticIp')]"
          }
        ]
      },
      "dependsOn": [
        "[resourceId('Microsoft.Network/privateDnsZones', parameters('defaultDomain'))]"
      ]
    }
  ]
}