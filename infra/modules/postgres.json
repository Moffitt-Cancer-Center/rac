{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.42.1.51946",
      "templateHash": "686121623948606645"
    }
  },
  "parameters": {
    "location": {
      "type": "string",
      "metadata": {
        "description": "Azure region for all resources"
      }
    },
    "serverName": {
      "type": "string",
      "metadata": {
        "description": "Postgres Flexible Server name"
      }
    },
    "adminPassword": {
      "type": "securestring",
      "metadata": {
        "description": "Postgres administrator login password (must come from Key Vault reference)"
      }
    },
    "skuName": {
      "type": "string",
      "metadata": {
        "description": "Postgres SKU name (e.g., Standard_B2s, Standard_D2s_v3)"
      }
    },
    "skuTier": {
      "type": "string",
      "metadata": {
        "description": "Postgres SKU tier (e.g., Burstable, GeneralPurpose)"
      }
    },
    "storageSizeGB": {
      "type": "int",
      "metadata": {
        "description": "Storage size in GB"
      }
    },
    "haMode": {
      "type": "string",
      "metadata": {
        "description": "High Availability mode (Disabled, SameZone, ZoneRedundant)"
      }
    },
    "backupRetentionDays": {
      "type": "int",
      "metadata": {
        "description": "Backup retention days"
      }
    },
    "peSubnetId": {
      "type": "string",
      "metadata": {
        "description": "Private endpoint subnet resource ID"
      }
    },
    "vnetId": {
      "type": "string",
      "metadata": {
        "description": "VNet resource ID for private DNS zone linking"
      }
    },
    "extensions": {
      "type": "array",
      "defaultValue": [
        "pg_uuidv7"
      ],
      "metadata": {
        "description": "Postgres extensions to enable"
      }
    },
    "geoRedundantBackup": {
      "type": "string",
      "defaultValue": "Disabled",
      "allowedValues": [
        "Enabled",
        "Disabled"
      ],
      "metadata": {
        "description": "Geo-redundant backup setting (Enabled or Disabled)"
      }
    },
    "tags": {
      "type": "object",
      "metadata": {
        "description": "Resource tags applied to all resources"
      }
    }
  },
  "resources": [
    {
      "type": "Microsoft.DBforPostgreSQL/flexibleServers",
      "apiVersion": "2023-06-01-preview",
      "name": "[parameters('serverName')]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "sku": {
        "name": "[parameters('skuName')]",
        "tier": "[parameters('skuTier')]"
      },
      "properties": {
        "version": "16",
        "administratorLogin": "rac_admin",
        "administratorLoginPassword": "[parameters('adminPassword')]",
        "storage": {
          "storageSizeGB": "[parameters('storageSizeGB')]"
        },
        "backup": {
          "backupRetentionDays": "[parameters('backupRetentionDays')]",
          "geoRedundantBackup": "[parameters('geoRedundantBackup')]"
        },
        "highAvailability": {
          "mode": "[parameters('haMode')]"
        },
        "network": {
          "publicNetworkAccess": "Disabled"
        }
      }
    },
    {
      "type": "Microsoft.DBforPostgreSQL/flexibleServers/configurations",
      "apiVersion": "2023-06-01-preview",
      "name": "[format('{0}/{1}', parameters('serverName'), 'azure.extensions')]",
      "properties": {
        "value": "[join(parameters('extensions'), ',')]",
        "source": "user-override"
      },
      "dependsOn": [
        "[resourceId('Microsoft.DBforPostgreSQL/flexibleServers', parameters('serverName'))]"
      ]
    },
    {
      "type": "Microsoft.Network/privateDnsZones",
      "apiVersion": "2020-06-01",
      "name": "privatelink.postgres.database.azure.com",
      "location": "global",
      "tags": "[parameters('tags')]"
    },
    {
      "type": "Microsoft.Network/privateDnsZones/virtualNetworkLinks",
      "apiVersion": "2020-06-01",
      "name": "[format('{0}/{1}', 'privatelink.postgres.database.azure.com', format('link-postgres-{0}', parameters('location')))]",
      "location": "global",
      "properties": {
        "registrationEnabled": false,
        "virtualNetwork": {
          "id": "[parameters('vnetId')]"
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Network/privateDnsZones', 'privatelink.postgres.database.azure.com')]"
      ]
    },
    {
      "type": "Microsoft.Network/privateEndpoints",
      "apiVersion": "2024-05-01",
      "name": "[format('pe-postgres-{0}', parameters('location'))]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "properties": {
        "subnet": {
          "id": "[parameters('peSubnetId')]"
        },
        "privateLinkServiceConnections": [
          {
            "name": "postgres-connection",
            "properties": {
              "privateLinkServiceId": "[resourceId('Microsoft.DBforPostgreSQL/flexibleServers', parameters('serverName'))]",
              "groupIds": [
                "postgresqlServer"
              ]
            }
          }
        ]
      },
      "dependsOn": [
        "[resourceId('Microsoft.DBforPostgreSQL/flexibleServers', parameters('serverName'))]"
      ]
    },
    {
      "type": "Microsoft.Network/privateEndpoints/privateDnsZoneGroups",
      "apiVersion": "2024-05-01",
      "name": "[format('{0}/{1}', format('pe-postgres-{0}', parameters('location')), 'postgres-zone-group')]",
      "properties": {
        "privateDnsZoneConfigs": [
          {
            "name": "postgres-config",
            "properties": {
              "privateDnsZoneId": "[resourceId('Microsoft.Network/privateDnsZones', 'privatelink.postgres.database.azure.com')]"
            }
          }
        ]
      },
      "dependsOn": [
        "[resourceId('Microsoft.Network/privateDnsZones', 'privatelink.postgres.database.azure.com')]",
        "[resourceId('Microsoft.Network/privateEndpoints', format('pe-postgres-{0}', parameters('location')))]"
      ]
    }
  ],
  "outputs": {
    "serverId": {
      "type": "string",
      "metadata": {
        "description": "Postgres server resource ID"
      },
      "value": "[resourceId('Microsoft.DBforPostgreSQL/flexibleServers', parameters('serverName'))]"
    },
    "serverFqdn": {
      "type": "string",
      "metadata": {
        "description": "Postgres server FQDN"
      },
      "value": "[reference(resourceId('Microsoft.DBforPostgreSQL/flexibleServers', parameters('serverName')), '2023-06-01-preview').fullyQualifiedDomainName]"
    }
  }
}