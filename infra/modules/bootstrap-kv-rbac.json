      "properties": {
        "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', variables('roleIds').keyVaultSecretsUser)]",
        "principalId": "[parameters('appGwMiPrincipalId')]",
        "principalType": "ServicePrincipal"
      }
    },
    "certificatesUserForAppGw": {
      "type": "Microsoft.Authorization/roleAssignments",
