{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.42.1.51946",
      "templateHash": "6967461495362003969"
    }
  },
  "parameters": {
    "location": {
      "type": "string",
      "metadata": {
        "description": "Azure region for all resources"
      }
    },
    "racEnv": {
      "type": "string",
      "metadata": {
        "description": "RAC deployment environment (dev, staging, prod)"
      }
    },
    "envName": {
      "type": "string",
      "metadata": {
        "description": "ACA managed environment name"
      }
    },
    "acaSubnetId": {
      "type": "string",
      "metadata": {
        "description": "ACA infrastructure subnet resource ID"
      }
    },
    "workspaceCustomerId": {
      "type": "string",
      "metadata": {
        "description": "Log Analytics workspace custom ID (customer ID)"
      }
    },
    "workspaceId": {
      "type": "string",
      "metadata": {
        "description": "Log Analytics workspace resource ID"
      }
    },
    "zoneRedundant": {
      "type": "bool",
      "metadata": {
        "description": "Enable zone redundancy for ACA environment"
      }
    },
    "profileSku": {
      "type": "string",
      "metadata": {
        "description": "Workload profile SKU (e.g., Consumption, D4)"
      }
    },
    "tags": {
      "type": "object",
      "metadata": {
        "description": "Resource tags applied to all resources"
      }
    }
  },
  "resources": [
    {
      "type": "Microsoft.App/managedEnvironments",
      "apiVersion": "2024-03-01",
      "name": "[parameters('envName')]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "properties": {
        "appLogsConfiguration": {
          "destination": "log-analytics",
          "logAnalyticsConfiguration": {
            "customerId": "[parameters('workspaceCustomerId')]",
            "sharedKey": "[listKeys(parameters('workspaceId'), '2023-09-01').primarySharedKey]"
          }
        },
        "vnetConfiguration": {
          "infrastructureSubnetId": "[parameters('acaSubnetId')]",
          "internal": true
        },
        "zoneRedundant": "[parameters('zoneRedundant')]",
        "workloadProfiles": [
          {
            "name": "Consumption",
            "workloadProfileType": "Consumption"
          },
          {
            "name": "apps",
            "workloadProfileType": "[parameters('profileSku')]"
          }
        ]
      }
    }
  ],
  "outputs": {
    "envId": {
      "type": "string",
      "metadata": {
        "description": "ACA managed environment resource ID"
      },
      "value": "[resourceId('Microsoft.App/managedEnvironments', parameters('envName'))]"
    },
    "envDefaultDomain": {
      "type": "string",
      "metadata": {
        "description": "ACA default domain (internal FQDN)"
      },
      "value": "[reference(resourceId('Microsoft.App/managedEnvironments', parameters('envName')), '2024-03-01').defaultDomain]"
    },
    "envStaticIp": {
      "type": "string",
      "metadata": {
        "description": "ACA static IP address"
      },
      "value": "[reference(resourceId('Microsoft.App/managedEnvironments', parameters('envName')), '2024-03-01').staticIp]"
    }
  }
}