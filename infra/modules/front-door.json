      "properties": {
        "hostName": "[parameters('appGatewayPublicFqdn')]",
        "httpPort": 80,
        "httpsPort": 443,
        "originHostHeader": "[parameters('appGatewayPublicFqdn')]",
        "priority": 1,
        "weight": 1000,
        "enabledState": "Enabled",
        "sharedPrivateLinkResource": "[if(and(not(empty(parameters('appGatewayPrivateLinkResourceId'))), not(empty(parameters('privateLinkLocation')))), createObject('privateLink', createObject('id', parameters('appGatewayPrivateLinkResourceId')), 'groupId', 'appgw', 'privateLinkLocation', parameters('privateLinkLocation')), null())]"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Cdn/profiles/originGroups', format('afd-rac-{0}', parameters('racEnv')), format('og-appgw-{0}', parameters('racEnv')))]"
      ]
    },
    {
      "type": "Microsoft.Cdn/profiles/afdEndpoints/routes",
