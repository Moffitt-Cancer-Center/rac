      "type": "string",
      "metadata": {
        "description": "Deployment environment: dev | staging | prod"
      }
    },
    "parentDomain": {
      "type": "string",
      "metadata": {
        "description": "Parent DNS domain, e.g., rac.moffitt.org"
      }
    },
    "appGatewayPublicFqdn": {
      "type": "string",
      "metadata": {
        "description": "App Gateway public FQDN"
      }
    },
    "appGatewayPrivateLinkResourceId": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "App Gateway Private Link resource ID (empty if using public FQDN origin)"
      }
    },
    "privateLinkLocation": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Azure region for shared private link location (empty to skip private link)"
      }
    },
    "tags": {
      "type": "object",
      "metadata": {
        "description": "Resource tags"
      }
    }
  },
  "resources": [
    {
      "type": "Microsoft.Cdn/profiles",
      "apiVersion": "2023-05-01",
      "name": "[format('afd-rac-{0}', parameters('racEnv'))]",
      "location": "global",
      "tags": "[parameters('tags')]",
      "sku": {
        "name": "Premium_AzureFrontDoor"
      }
    },
    {
      "type": "Microsoft.Cdn/profiles/afdEndpoints",
      "apiVersion": "2023-05-01",
