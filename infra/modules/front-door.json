      "name": "[format('{0}/{1}/{2}', format('afd-rac-{0}', parameters('racEnv')), format('afd-endpoint-{0}', parameters('racEnv')), format('route-wildcard-{0}', parameters('racEnv')))]",
      "properties": {
        "originGroup": {
          "id": "[resourceId('Microsoft.Cdn/profiles/originGroups', format('afd-rac-{0}', parameters('racEnv')), format('og-appgw-{0}', parameters('racEnv')))]"
        },
        "supportedProtocols": [
          "Https"
        ],
        "patternsToMatch": [
          "/*"
        ],
        "forwardingProtocol": "HttpsOnly",
        "linkToDefaultDomain": "Enabled",
        "httpsRedirect": "Enabled",
        "enabledState": "Enabled",
        "customDomains": [
          {
            "id": "[resourceId('Microsoft.Cdn/profiles/customDomains', format('afd-rac-{0}', parameters('racEnv')), format('domain-wildcard-{0}', parameters('racEnv')))]"
          }
        ]
      },
      "dependsOn": [
        "[resourceId('Microsoft.Cdn/profiles/customDomains', format('afd-rac-{0}', parameters('racEnv')), format('domain-wildcard-{0}', parameters('racEnv')))]",
        "[resourceId('Microsoft.Cdn/profiles/afdEndpoints', format('afd-rac-{0}', parameters('racEnv')), format('afd-endpoint-{0}', parameters('racEnv')))]",
        "[resourceId('Microsoft.Cdn/profiles/originGroups', format('afd-rac-{0}', parameters('racEnv')), format('og-appgw-{0}', parameters('racEnv')))]"
      ]
    },
    {
      "type": "Microsoft.Cdn/profiles/customDomains",
      "apiVersion": "2023-05-01",
      "name": "[format('{0}/{1}', format('afd-rac-{0}', parameters('racEnv')), format('domain-wildcard-{0}', parameters('racEnv')))]",
      "properties": {
        "hostName": "[format('*.{0}', parameters('parentDomain'))]",
        "tlsSettings": {
          "certificateType": "ManagedCertificate",
          "minimumTlsVersion": "TLS12"
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Cdn/profiles', format('afd-rac-{0}', parameters('racEnv')))]"
      ]
    },
    {
      "type": "Microsoft.Network/FrontDoorWebApplicationFirewallPolicies",
      "apiVersion": "2022-05-01",
      "name": "[format('waf-rac-{0}', parameters('racEnv'))]",
      "location": "global",
      "tags": "[parameters('tags')]",
      "properties": {
        "policySettings": {
          "enabledState": "Enabled",
          "mode": "Prevention"
        },
        "managedRules": {
          "managedRuleSets": [
            {
              "ruleSetType": "Microsoft_DefaultRuleSet",
              "ruleSetVersion": "2.1"
            }
          ]
        }
      }
    },
    {
      "type": "Microsoft.Cdn/profiles/securityPolicies",
      "apiVersion": "2023-05-01",
      "name": "[format('{0}/{1}', format('afd-rac-{0}', parameters('racEnv')), format('secpol-{0}', parameters('racEnv')))]",
      "properties": {
        "parameters": {
          "type": "WebApplicationFirewall",
          "wafPolicy": {
            "id": "[resourceId('Microsoft.Network/FrontDoorWebApplicationFirewallPolicies', format('waf-rac-{0}', parameters('racEnv')))]"
          },
          "associations": [
            {
              "domains": [
                {
                  "id": "[resourceId('Microsoft.Cdn/profiles/afdEndpoints', format('afd-rac-{0}', parameters('racEnv')), format('afd-endpoint-{0}', parameters('racEnv')))]"
                }
              ],
              "patternsToMatch": [
                "/*"
              ]
            }
          ]
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Cdn/profiles/afdEndpoints', format('afd-rac-{0}', parameters('racEnv')), format('afd-endpoint-{0}', parameters('racEnv')))]",
        "[resourceId('Microsoft.Cdn/profiles', format('afd-rac-{0}', parameters('racEnv')))]",
        "[resourceId('Microsoft.Network/FrontDoorWebApplicationFirewallPolicies', format('waf-rac-{0}', parameters('racEnv')))]"
      ]
    }
  ],
  "outputs": {
    "frontDoorProfileId": {
      "type": "string",
      "metadata": {
        "description": "Front Door Profile resource ID"
      },
      "value": "[resourceId('Microsoft.Cdn/profiles', format('afd-rac-{0}', parameters('racEnv')))]"
    },
    "frontDoorEndpointHostname": {
      "type": "string",
      "metadata": {
        "description": "Front Door endpoint hostname"
      },
      "value": "[reference(resourceId('Microsoft.Cdn/profiles/afdEndpoints', format('afd-rac-{0}', parameters('racEnv')), format('afd-endpoint-{0}', parameters('racEnv'))), '2023-05-01').hostName]"
    },
    "wafPolicyId": {
      "type": "string",
      "metadata": {
        "description": "WAF Policy resource ID"
      },
      "value": "[resourceId('Microsoft.Network/FrontDoorWebApplicationFirewallPolicies', format('waf-rac-{0}', parameters('racEnv')))]"
    }
  }
