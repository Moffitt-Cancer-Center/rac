{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.42.1.51946",
      "templateHash": "5617436465315707346"
    }
  },
  "parameters": {
    "location": {
      "type": "string",
      "metadata": {
        "description": "Azure region for all resources"
      }
    },
    "racEnv": {
      "type": "string",
      "metadata": {
        "description": "RAC deployment environment (dev, staging, prod)"
      }
    },
    "actionGroupEmails": {
      "type": "array",
      "defaultValue": [],
      "metadata": {
        "description": "Email addresses for alert action group (comma-separated)"
      }
    },
    "actionGroupWebhookUri": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Webhook URI for alert action group (optional)"
      }
    },
    "shimAppId": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Shim ACA app resource ID (empty on first deploy)"
      }
    },
    "controlPlaneAppId": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Control Plane ACA app resource ID (empty on first deploy)"
      }
    },
    "postgresServerId": {
      "type": "string",
      "metadata": {
        "description": "Postgres Flexible Server resource ID"
      }
    },
    "kvId": {
      "type": "string",
      "metadata": {
        "description": "Key Vault resource ID"
      }
    },
    "logAnalyticsWorkspaceId": {
      "type": "string",
      "metadata": {
        "description": "Log Analytics workspace resource ID"
      }
    },
    "pipelineTimeoutMinutes": {
      "type": "int",
      "defaultValue": 120,
      "maxValue": 180,
      "metadata": {
        "description": "Pipeline timeout in minutes (used for stuck-pipeline alert threshold). Max 180 min due to Azure 360-min schema limit (2x multiplier for alert window)."
      }
    },
    "deployTelemetryAlerts": {
      "type": "bool",
      "defaultValue": false,
      "metadata": {
        "description": "Deploy alerts that depend on telemetry tables/columns (ContainerAppConsoleLogs_CL.StatusCode_d, RAC_PipelineLog_CL). Azure validates KQL at create time, so these fail on a fresh workspace before the app has emitted any structured logs. Flip true once logs are flowing."
      }
    },
    "tags": {
      "type": "object",
      "metadata": {
        "description": "Resource tags applied to all resources"
      }
    }
  },
  "resources": [
    {
      "type": "Microsoft.Insights/actionGroups",
      "apiVersion": "2023-01-01",
      "name": "[format('ag-rac-{0}', parameters('racEnv'))]",
      "location": "global",
      "tags": "[parameters('tags')]",
      "properties": {
        "copy": [
          {
            "name": "emailReceivers",
            "count": "[length(parameters('actionGroupEmails'))]",
            "input": {
              "name": "[format('email-{0}', copyIndex('emailReceivers'))]",
              "emailAddress": "[parameters('actionGroupEmails')[copyIndex('emailReceivers')]]",
              "useCommonAlertSchema": true
            }
          }
        ],
        "groupShortName": "[format('rac-{0}', parameters('racEnv'))]",
        "enabled": true,
        "webhookReceivers": "[if(not(empty(parameters('actionGroupWebhookUri'))), createArray(createObject('name', 'webhook-receiver', 'serviceUri', parameters('actionGroupWebhookUri'), 'useCommonAlertSchema', true())), createArray())]"
      }
    },
    {
      "condition": "[and(not(empty(parameters('shimAppId'))), parameters('deployTelemetryAlerts'))]",
      "type": "Microsoft.Insights/scheduledQueryRules",
      "apiVersion": "2023-03-15-preview",
      "name": "[format('alert-shim-5xx-{0}', parameters('racEnv'))]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "properties": {
        "description": "Shim application 5xx error rate > 1% over 5 minutes",
        "enabled": true,
        "severity": 2,
        "scopes": [
          "[parameters('logAnalyticsWorkspaceId')]"
        ],
        "evaluationFrequency": "PT1M",
        "windowSize": "PT5M",
        "criteria": {
          "allOf": [
            {
              "query": "          ContainerAppConsoleLogs_CL\n          | where ContainerAppName_s == \"shim\"\n          | summarize total = count(), fivexx = countif(StatusCode_d >= 500) by bin(TimeGenerated, 1m)\n          | extend rate = fivexx * 100.0 / total\n          | where rate > 1.0 and total > 20\n          ",
              "timeAggregation": "Count",
              "operator": "GreaterThan",
              "threshold": 0,
              "failingPeriods": {
                "numberOfEvaluationPeriods": 1,
                "minFailingPeriodsToAlert": 1
              }
            }
          ]
        },
        "actions": {
          "actionGroups": [
            "[resourceId('Microsoft.Insights/actionGroups', format('ag-rac-{0}', parameters('racEnv')))]"
          ]
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Insights/actionGroups', format('ag-rac-{0}', parameters('racEnv')))]"
      ]
    },
    {
      "condition": "[and(not(empty(parameters('controlPlaneAppId'))), parameters('deployTelemetryAlerts'))]",
      "type": "Microsoft.Insights/scheduledQueryRules",
      "apiVersion": "2023-03-15-preview",
      "name": "[format('alert-controlplane-5xx-{0}', parameters('racEnv'))]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "properties": {
        "description": "Control Plane application 5xx error rate > 1% over 5 minutes",
        "enabled": true,
        "severity": 2,
        "scopes": [
          "[parameters('logAnalyticsWorkspaceId')]"
        ],
        "evaluationFrequency": "PT1M",
        "windowSize": "PT5M",
        "criteria": {
          "allOf": [
            {
              "query": "          ContainerAppConsoleLogs_CL\n          | where ContainerAppName_s == \"controlplane\"\n          | summarize total = count(), fivexx = countif(StatusCode_d >= 500) by bin(TimeGenerated, 1m)\n          | extend rate = fivexx * 100.0 / total\n          | where rate > 1.0 and total > 20\n          ",
              "timeAggregation": "Count",
              "operator": "GreaterThan",
              "threshold": 0,
              "failingPeriods": {
                "numberOfEvaluationPeriods": 1,
                "minFailingPeriodsToAlert": 1
              }
            }
          ]
        },
        "actions": {
          "actionGroups": [
            "[resourceId('Microsoft.Insights/actionGroups', format('ag-rac-{0}', parameters('racEnv')))]"
          ]
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Insights/actionGroups', format('ag-rac-{0}', parameters('racEnv')))]"
      ]
    },
    {
      "type": "Microsoft.Insights/metricAlerts",
      "apiVersion": "2018-03-01",
      "name": "[format('alert-postgres-connection-failures-{0}', parameters('racEnv'))]",
      "location": "global",
      "tags": "[parameters('tags')]",
      "properties": {
        "description": "Postgres connection failures > 0 over 5 minutes",
        "enabled": true,
        "severity": 1,
        "scopes": [
          "[parameters('postgresServerId')]"
        ],
        "evaluationFrequency": "PT1M",
        "windowSize": "PT5M",
        "criteria": {
          "odata.type": "Microsoft.Azure.Monitor.MultipleResourceMultipleMetricCriteria",
          "allOf": [
            {
              "name": "connection-failures",
              "criterionType": "StaticThresholdCriterion",
              "metricName": "connections_failed",
              "metricNamespace": "Microsoft.DBforPostgreSQL/flexibleServers",
              "operator": "GreaterThan",
              "threshold": 0,
              "timeAggregation": "Total"
            }
          ]
        },
        "actions": [
          {
            "actionGroupId": "[resourceId('Microsoft.Insights/actionGroups', format('ag-rac-{0}', parameters('racEnv')))]",
            "webHookProperties": {}
          }
        ]
      },
      "dependsOn": [
        "[resourceId('Microsoft.Insights/actionGroups', format('ag-rac-{0}', parameters('racEnv')))]"
      ]
    },
    {
      "type": "Microsoft.Insights/metricAlerts",
      "apiVersion": "2018-03-01",
      "name": "[format('alert-keyvault-access-denied-{0}', parameters('racEnv'))]",
      "location": "global",
      "tags": "[parameters('tags')]",
      "properties": {
        "description": "Key Vault access denied errors > 0 over 5 minutes",
        "enabled": true,
        "severity": 1,
        "scopes": [
          "[parameters('kvId')]"
        ],
        "evaluationFrequency": "PT1M",
        "windowSize": "PT5M",
        "criteria": {
          "odata.type": "Microsoft.Azure.Monitor.MultipleResourceMultipleMetricCriteria",
          "allOf": [
            {
              "name": "access-denied",
              "criterionType": "StaticThresholdCriterion",
              "metricName": "ServiceApiResult",
              "metricNamespace": "Microsoft.KeyVault/vaults",
              "operator": "GreaterThan",
              "threshold": 0,
              "timeAggregation": "Total",
              "dimensions": [
                {
                  "name": "StatusCode",
                  "operator": "Include",
                  "values": [
                    "403"
                  ]
                }
              ]
            }
          ]
        },
        "actions": [
          {
            "actionGroupId": "[resourceId('Microsoft.Insights/actionGroups', format('ag-rac-{0}', parameters('racEnv')))]",
            "webHookProperties": {}
          }
        ]
      },
      "dependsOn": [
        "[resourceId('Microsoft.Insights/actionGroups', format('ag-rac-{0}', parameters('racEnv')))]"
      ]
    },
    {
      "condition": "[and(not(empty(parameters('controlPlaneAppId'))), parameters('deployTelemetryAlerts'))]",
      "type": "Microsoft.Insights/scheduledQueryRules",
      "apiVersion": "2023-03-15-preview",
      "name": "[format('alert-pipeline-stuck-{0}', parameters('racEnv'))]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "properties": {
        "description": "Pipeline workflow stuck > 2x timeout without terminal verdict",
        "enabled": true,
        "severity": 2,
        "scopes": [
          "[parameters('logAnalyticsWorkspaceId')]"
        ],
        "evaluationFrequency": "PT5M",
        "windowSize": "[format('PT{0}M', mul(2, parameters('pipelineTimeoutMinutes')))]",
        "criteria": {
          "allOf": [
            {
              "query": "[format('let window_start = ago({0}m);\nlet started = RAC_PipelineLog_CL\n| where TimeGenerated between (window_start .. now())\n| where event_type_s == \"pipeline_started\"\n| project correlation_id_s, started_at = TimeGenerated;\nlet verdicts = RAC_PipelineLog_CL\n| where TimeGenerated between (window_start .. now())\n| where event_type_s == \"pipeline_verdict\"\n| project correlation_id_s;\nstarted\n| where correlation_id_s !in (verdicts)\n| where started_at < ago({1}m)\n| summarize stuck_count = count()', mul(2, parameters('pipelineTimeoutMinutes')), parameters('pipelineTimeoutMinutes'))]",
              "timeAggregation": "Count",
              "operator": "GreaterThan",
              "threshold": 0,
              "failingPeriods": {
                "numberOfEvaluationPeriods": 1,
                "minFailingPeriodsToAlert": 1
              }
            }
          ]
        },
        "actions": {
          "actionGroups": [
            "[resourceId('Microsoft.Insights/actionGroups', format('ag-rac-{0}', parameters('racEnv')))]"
          ]
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Insights/actionGroups', format('ag-rac-{0}', parameters('racEnv')))]"
      ]
    }
  ],
  "outputs": {
    "actionGroupId": {
      "type": "string",
      "metadata": {
        "description": "Action Group resource ID"
      },
      "value": "[resourceId('Microsoft.Insights/actionGroups', format('ag-rac-{0}', parameters('racEnv')))]"
    }
  }
}